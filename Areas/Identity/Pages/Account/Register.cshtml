@page
@model AspNetIdentityLab.Areas.Identity.Pages.Account.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <title>Register</title>
    <style>       * { 
        margin: 0; 
        padding: 0; 
        box-sizing: border-box;
         font-family: 'Segoe UI', sans-serif;
         }
        body { 
            background: #f0f0f0;
             display: flex;
              justify-content: center; 
              align-items: center; 
              min-height: 100vh; 
              flex-direction: column;
               gap: 24px; 
               padding: 40px; }

        .card {
            background: white; 
            border-radius: 12px; 
            padding: 32px;
            width: 100%; 
            max-width: 360px;
            border-top: 4px solid #2e7d32;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }
        h2 { 
            text-align: center; 
            margin-bottom: 24px; 
            font-size: 1.2rem;
         }

        label {
             font-size: 13px; 
             color: #444;
              display: block; 
              margin-bottom: 4px;
             }
        select, input {
            width: 100%; 
            padding: 10px 14px; 
            border: 1px solid #ddd;
            border-radius: 6px;
             font-size: 14px; 
             margin-bottom: 16px;
            background: white;
        }
        select:focus, input:focus {
             outline: none;
              border-color: #2e7d32; }

        .btn-next {
            width: 100%;
             padding: 12px;
              background: #2e7d32;
               color: white;
            border: none; 
            border-radius: 8px;
             font-size: 15px; 
             cursor: pointer;
        }
</style>
</head>
<body>
    <div class="card">
        <h2>Account Registration</h2>
        <form method="post">
            <label>Course:</label>
            <select asp-for="Input.Course">
                <option value="">Plsease Select</option>
                <option>BSIT</option>
                <option>BIT</option>
            </select>

            <label>Year Level:</label>
            <select asp-for="Input.YearLevel">
                <option value="">Plsease Select</option>
                <option>1st Year</option>
                <option>2nd Year</option>
                <option>3rd Year</option>
                <option>4th Year</option>
            </select>

            <label>Section:</label>
            <input asp-for="Input.Section" placeholder="Enter here" />

            <label>Student ID:</label>
            <input asp-for="Input.Email" placeholder="Enter here" />

            <label>Password:</label>
            <input asp-for="Input.Password" type="password" placeholder="Enter here" />

            <label>Re-try Password:</label>
            <input asp-for="Input.ConfirmPassword" type="password" placeholder="Enter here" />

            <button type="submit" class="btn-next">Next</button>
        </form>
    </div>
</body>
</html>