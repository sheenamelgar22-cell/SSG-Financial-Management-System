@page
@model AspNetIdentityLab.Areas.Identity.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>SSG Login</title>
    <style>* { margin: 0; 
    padding: 0; 
    box-sizing: border-box;
     font-family: 'Segoe UI', sans-serif;
     }

 body { display: flex; height: 100vh; 
}

.left-panel {
    background: #2e7d32;
    width: 40%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 40px;
    color: white;
  }
 .logo {
     display: flex; 
     align-items: center; 
     gap: 12px; 
    }
        .logo-circle {
            background: #f9a825;
             width: 48px;
              height: 48px;
            border-radius: 50%; display: flex;
             align-items: center;
            justify-content: center; 
            font-weight: bold; 
            font-size: 20px; color: #2e7d32;
        }
        .logo-text h2 {
            font-size: 16px;
         }
        .logo-text p { 
            font-size: 12px; 
            opacity: 0.8;
         }
        .tagline { 
            font-size: 2.2rem; 
            font-weight: bold;
             line-height: 1.3;
             }
        .subtitle { 
            font-size: 13px; 
            opacity: 0.8; 
            margin-top: 12px;
         }
        .footer { 
            font-size: 12px; 
            opacity: 0.6; 
        }

        .right-panel {
            width: 60%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px;
            background: white;
        }
        .form-box { 
            width: 100%;
             max-width: 420px; 
            }
        .form-box h2 { 
            font-size: 1.8rem; 
            margin-bottom: 6px;
         }
        .form-box p { 
            color: #666; 
            margin-bottom: 20px; 
            font-size: 14px; 
        }

        .role-tabs { 
            display: flex; 
            gap: 8px; margin-bottom: 20px;
         }
        .role-tab {
            padding: 6px 18px;
             border-radius: 20px;
              border: 1px solid #ccc;
            cursor: pointer; 
            font-size: 14px; 
            background: white;
        }
        .role-tab.active { 
            background: #2e7d32; color:
             white; border-color: #2e7d32;
             }

        input[type=email], 
        input[type=password] {
            width: 100%;
             padding: 12px 16px; 
             margin-bottom: 14px;
            border: 1px solid #ddd;
             border-radius: 8px;
              font-size: 14px;
        }
        input:focus {
             outline: none; 
             border-color: #2e7d32;
             }

        .forgot { 
            font-size: 13px; 
            color: #2e7d32;
             text-decoration: none;
              display: block; 
              margin-bottom: 20px; 
            }

        .btn-login {
            width: 100%; 
            padding: 13px; 
            background: #2e7d32;
             color: white;
            border: none;
             border-radius: 8px; 
             font-size: 15px; cursor: pointer;
            margin-bottom: 16px;
        }
        .btn-signup {
            width: 100%;
             padding: 13px; 
             background: white;
             color: #2e7d32;
            border: 2px solid #2e7d32; 
            border-radius: 8px; font-size: 15px;
            cursor: pointer;
             text-align: center;
             display: block; 
             text-decoration: none;
        }
        .signup-text { 
            font-size: 13px;
             color: #666; 
             margin-bottom: 8px; 
            }
</style>
</head>
<body>
    <div class="left-panel">
        <div class="logo">
            <div class="logo-circle">g</div>
            <div class="logo-text">
                <h2>CTU - Ginatilan</h2>
                <p>Supreme Student Government</p>
            </div>
        </div>
        <div>
            <div class="tagline">Track your Organizational Fees!</div>
            <p class="subtitle">A transparent and real-time system for tracking and managing organizational fees.</p>
        </div>
        <div class="footer">No Copyright</div>
    </div>

    <div class="right-panel">
        <div class="form-box">
            <h2>Sign in</h2>
            <p>Please choose your role</p>

            <div class="role-tabs">
                <button class="role-tab active" onclick="setRole('Student', this)">Student</button>
                <button class="role-tab" onclick="setRole('Treasurer', this)">Treasurer</button>
                <button class="role-tab" onclick="setRole('Admin', this)">Admin</button>
            </div>

            <form method="post">
                <input type="hidden" name="Input.Role" id="roleInput" value="Student" />
                <input asp-for="Input.Email" type="email" placeholder="Enter your Email" />
                <input asp-for="Input.Password" type="password" placeholder="Enter your Password" />
                <a href="#" class="forgot">Forgot password?</a>
                <button type="submit" class="btn-login">Sign in</button>
                <p class="signup-text">Don't have an <strong>account?</strong></p>
                <a href="/Identity/Account/Register" class="btn-signup">Sign up</a>
            </form>
        </div>
    </div>

    <script>
        function setRole(role, el) {
            document.getElementById('roleInput').value = role;
            document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }
    </script>
</body>
</html>